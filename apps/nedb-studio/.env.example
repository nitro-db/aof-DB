# ── NEDB Studio environment ────────────────────────────────────────────────
# Copy to `.env` and fill in. With NO AiAssist credentials, Studio runs in
# deterministic MOCK MODE (fully usable). With credentials, it uses AiAssist
# as the AI gateway. The API key is ONLY ever read server-side (server.ts /
# src/server) — it is never exposed to the browser.

# AiAssist gateway (AiAssist Secure / AiAS). All AI generation goes through this.
AIASSIST_BASE_URL=https://your-aiassist-host.example.com
AIASSIST_API_KEY=replace_me

# Default generation provider + model. X-AiAssist-Provider is sent on EVERY call.
AIASSIST_DEFAULT_PROVIDER=anthropic
AIASSIST_DEFAULT_MODEL=claude-sonnet-4-6

# Runner (fast scaffold generation)
AIASSIST_RUNNER_PROVIDER=anthropic
AIASSIST_RUNNER_MODEL=claude-sonnet-4-6

# Sentinel (validation / repair / schema-consistency pass)
AIASSIST_SENTINEL_PROVIDER=anthropic
AIASSIST_SENTINEL_MODEL=claude-sonnet-4-6

# Server port for the AiAssist proxy/generation API (Vite dev proxies /api here)
PORT=3001
